---
/**
 * Shared hero for every service page (18 templates -> ~1,027 generated pages).
 *
 * Layout: breadcrumb full width, then a 7/5 grid on desktop — copy and calls to
 * action on the left, evidence panel on the right. The right-hand space was
 * previously unused; it now carries proof rather than decoration.
 *
 * Mobile: the grid collapses and DOM order becomes the reading order —
 * H1, intro, call, enquiry, evidence. Contact actions deliberately sit ABOVE the
 * evidence panel so they are reachable without scrolling; mobile is 55% of clicks.
 * No CSS `order` and no duplicated markup, so nothing is announced twice.
 *
 * The badge was removed: it repeated the breadcrumb and the H1, in a third
 * vocabulary ("Fitted Kitchens" above an H1 reading "Kitchen Installers").
 *
 * Core Web Vitals: no large hero image. The <h1> stays the LCP element; the
 * portrait is small and carries no fetchpriority so it cannot displace it.
 */
import Breadcrumb from "./Breadcrumb.astro";
import ProminentPhoneButton from "./ProminentPhoneButton.astro";
import HeroEvidencePanel from "./HeroEvidencePanel.astro";
import { DETAILS } from "../constants/details";

interface Props {
  title: string;
  description: string;
  breadcrumbCrumbs: Array<{ label: string; href?: string; current?: boolean }>;
  /** Accepted for backwards compatibility with the 18 service templates; no longer rendered. */
  badge?: string;
}

const { title, description, breadcrumbCrumbs } = Astro.props;
---

<section class="bg-white py-8 lg:py-12">
  <div class="container-wide">
    <div class="mb-6">
      <Breadcrumb crumbs={breadcrumbCrumbs} />
    </div>

    <div class="grid gap-8 lg:grid-cols-12 lg:gap-12">
      <!-- Copy + calls to action -->
      <div class="lg:col-span-7">
        <h1 class="mb-4 text-3xl font-bold text-neutral-900 lg:text-4xl">
          {title}
        </h1>

        <p class="mb-6 max-w-prose text-lg text-neutral-600">
          {description}
        </p>

        <div class="flex flex-col gap-3 sm:flex-row sm:items-start">
          <ProminentPhoneButton note={null} />

          <!--
            Secondary CTA. The enquiry form already exists on all 18 service
            templates with id="contact", so this is a same-page anchor: no new
            page, no second form, no extra JavaScript.
          -->
          <a
            href="#contact"
            class="inline-flex min-h-[48px] items-center justify-center gap-2 rounded-lg border-2 border-brand-600 px-6 py-3 text-lg font-semibold text-brand-700 transition-colors duration-200 hover:bg-brand-50 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-brand-300 focus-visible:ring-offset-2"
          >
            Send an enquiry
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>

        <p class="mt-3 text-sm text-neutral-600">
          Prefer email? <a
            href={`mailto:${DETAILS.EMAIL}`}
            class="font-medium text-brand-700 underline-offset-2 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2"
            >{DETAILS.EMAIL}</a
          >
        </p>
      </div>

      <!-- Evidence: answers "can I trust you?" before the visitor scrolls -->
      <div class="lg:col-span-5">
        <HeroEvidencePanel />
      </div>
    </div>
  </div>
</section>
