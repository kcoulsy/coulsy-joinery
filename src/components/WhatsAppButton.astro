---
/**
 * WhatsApp click-to-chat.
 *
 * WHY THIS EXISTS — it is not "another way to contact us".
 *
 *   Every page already carries the phone number seven times over, with four `tel:` links.
 *   A fifth contact channel would be noise.
 *
 *   But Robert's actual workflow is: the phone rings, and he says "are you on WhatsApp?
 *   Send me some images and your postcode." The call isn't the channel — it's the FRICTION
 *   BEFORE the channel. And the people who will not ring a tradesman at all never get there.
 *
 *   So this lets them start where the conversation was going anyway, arriving with the two
 *   things needed to price a job without driving to it: PHOTOS and a POSTCODE.
 *
 * The pre-filled message asks for exactly that. Do not make it generic — "Hi, I'd like a
 * quote" throws away the whole point.
 *
 * Deliberately NOT a floating widget, a popup, or a repeated footer link.
 */
import { DETAILS } from "../constants/details";

interface Props {
  /**
   * HUMAN phrasing of the job, as a customer would say it — "a fitted kitchen in Leeds",
   * "door hanging in York". NOT the page title.
   *
   * The page title is an SEO string: "Kitchen Installers in Leeds". Dropped into a
   * sentence it becomes "I'd like a quote for Kitchen Installers in Leeds", which reads
   * as though the customer wants to buy some installers. Each service page supplies its
   * own natural wording instead.
   */
  quoteFor?: string;
  /** Visual weight. "secondary" sits beside Call Now; "link" is a plain text link. */
  variant?: "secondary" | "link";
}

const { quoteFor, variant = "secondary" } = Astro.props;

// Derived from DETAILS.PHONE so it cannot drift: "07544 030486" -> "447544030486".
// wa.me needs the international form with no +, spaces or leading zero.
const waNumber = DETAILS.PHONE.replace(/\D/g, "").replace(/^0/, "44");

// ─────────────────────────────────────────────────────────────────────────────────────────
// The message INVITES photos; it does not assume them. Not every enquiry has a photo to
// hand, and "here are some photos" reads oddly when there aren't any.
//
// The labelled gaps sit at the END, deliberately. WhatsApp places the cursor at the end of
// pre-filled text, so anything the customer is asked to complete mid-sentence ("my postcode
// is… I'm hoping to…") requires them to tap back into the middle of the message. Most people
// won't: they will ignore the gaps or send it with holes in. Only the trailing prompt gets
// filled reliably, so the two things Robert always needs are put there, plainly labelled.
//
// What this asks for is exactly what he asks for on every call: what the job is, where it
// is, when they want it, and photos if they have them.
// ─────────────────────────────────────────────────────────────────────────────────────────
const opener = quoteFor
  ? `Hi Robert, I'd like a quote for ${quoteFor}.`
  : `Hi Robert, I'd like a quote.`;

// ─────────────────────────────────────────────────────────────────────────────────────────
// ATTRIBUTION — deliberately a plain English sentence, not a tracking code.
//
// A wa.me click leaves the site: you can see that someone tapped a button, and nothing
// after that. Not whether they sent anything, not whether they became a customer, and not
// which site they came from. Counting clicks would be the same trap as counting impressions
// or inbound links — a number that moves without meaning.
//
// So the ATTRIBUTION TRAVELS IN THE MESSAGE. It arrives in Robert's WhatsApp, where the
// enquiry actually lands, with no analytics, no cookies and nothing hidden from the
// customer. `SRC=JOINERY-KITCHENS-LEEDS` would be tracking. A sentence saying which website
// it came from is just... information.
//
// WHERE IT SITS, AND WHY IT IS NOT LAST:
//   - not FIRST, because WhatsApp's notification preview shows the opening line, and that
//     line should tell Robert WHAT THE JOB IS, not where it came from;
//   - not LAST, because the cursor lands at the end of pre-filled text and the labelled
//     gaps have to be there for the customer to complete.
//
// When this component is ported to the Fire Doors site, change SITE_NAME — nothing else.
// That single line is what will eventually answer "is Fire Doors generating its own work?"
// ─────────────────────────────────────────────────────────────────────────────────────────
const SITE_NAME = "Coulsy Joinery";
const attribution = `Enquiry via the ${SITE_NAME} website.`;

const message = [
  // `locationInText` arrives as " in Leeds" (leading space), so collapse any doubles rather
  // than depending on 18 service pages getting the spacing right.
  `${opener} Happy to send photos if that helps.`.replace(/\s+/g, " ").trim(),
  attribution,
  `Postcode:\nTimescale:\nWhat's involved:`,
].join("\n\n");

const href = `https://wa.me/${waNumber}?text=${encodeURIComponent(message)}`;
---

{
  variant === "secondary" ? (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex min-h-[48px] items-center justify-center gap-2 rounded-lg border-2 border-[#25D366] px-6 py-3 text-lg font-semibold text-[#0d7a3c] transition-colors duration-200 hover:bg-[#25D366]/10 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#25D366]/40 focus-visible:ring-offset-2"
      aria-label="Send photos and your postcode on WhatsApp (opens WhatsApp in a new tab)"
    >
      <svg
        class="h-5 w-5 shrink-0"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
        focusable="false"
      >
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884a9.82 9.82 0 0 1 6.988 2.896 9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z" />
      </svg>
      Send photos on WhatsApp
    </a>
  ) : (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      class="font-medium text-brand-700 underline-offset-2 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2"
    >
      WhatsApp me photos and your postcode
    </a>
  )
}
