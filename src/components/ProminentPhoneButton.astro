---
// Reusable prominent phone button. Used by ServiceHero (all service pages) and
// by the homepage hero CTA.
import { DETAILS } from "../constants/details";

interface Props {
  /** Optional supporting line under the button. Pass null to omit it. */
  note?: string | null;
}

const { note = "Available for quotes and enquiries" } = Astro.props;

// tel: URIs must not contain spaces.
const telHref = `tel:${DETAILS.PHONE.replace(/\s+/g, "")}`;
---

<div class="mb-4">
  <a
    href={telHref}
    class="inline-flex items-center justify-center min-h-[48px] px-6 py-3 bg-green-700 text-white font-semibold rounded-lg hover:bg-green-800 transition-colors duration-200 text-lg shadow-md focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-green-300 focus-visible:ring-offset-2"
  >
    <svg
      class="mr-2 w-5 h-5"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
      focusable="false"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
      />
    </svg>
    Call Now: {DETAILS.PHONE}
  </a>
  {note && <p class="text-sm text-gray-500 mt-2">{note}</p>}
</div>
