---
// Google reviews. The reviews themselves live in one place — see
// `src/constants/reviews.ts` — because they used to be duplicated inside this
// file and the two copies drifted apart.
//
// No dates are shown. The old list stored relative phrases ("a month ago") that
// were correct the day they were written and wrong ever after: a September 2025
// review was still claiming "a month ago" in July 2026. Rather than ship a date
// that rots, we ship none. If dates ever come back, store absolute ones.
//
// The rating and count below are shown to READERS ONLY. They are deliberately not
// emitted as AggregateRating JSON-LD — see the note in `MainPage.astro`. Ratings a
// business publishes about itself are self-serving and ineligible for review stars.
import { REVIEWS, REVIEW_COUNT, AVERAGE_RATING } from "../constants/reviews";

const GOOGLE_REVIEWS_URL =
  "https://search.google.com/local/reviews?placeid=ChIJFREqq2Poe0gRFoS-2A2H_cg";

// Long reviews are clamped to a preview with a "Read more" toggle.
const PREVIEW_LENGTH = 150;
---

<section class="py-12">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-2xl font-bold text-gray-900 md:text-3xl">
        What Our Customers Say
      </h2>
      <p class="text-gray-500 mt-4 max-w-2xl mx-auto">
        We're proud to have earned the trust of our clients across Yorkshire.
        Here's what they have to say about working with Coulsy Joinery & Small
        Build.
      </p>

      {/* Derived from constants/reviews.ts — never hardcode these numbers. */}
      <p class="mt-6 flex items-center justify-center gap-2 text-gray-700">
        <span class="text-yellow-500 text-lg" aria-hidden="true">★★★★★</span>
        <span>
          <strong class="font-semibold">{AVERAGE_RATING} out of 5</strong>
          <span class="text-gray-500">
            {" "}({REVIEW_COUNT} reviews on Google)
          </span>
        </span>
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 xl:grid-cols-4 gap-6">
      {
        REVIEWS.map((review, index) => {
          const isLongReview = review.text.length > PREVIEW_LENGTH;
          const truncatedText = isLongReview
            ? review.text.slice(0, PREVIEW_LENGTH) + "..."
            : review.text;
          const reviewId = `review-${index}-${review.author.replace(/\s+/g, "-").toLowerCase()}`;

          return (
            <div class="p-6 border border-gray-200 rounded-lg shadow-sm bg-white hover:shadow-md transition-shadow h-full flex flex-col">
              <div class="flex items-center gap-4 mb-4">
                <div>
                  <div class="font-semibold text-lg">{review.author}</div>
                  <div
                    class="text-yellow-500 flex gap-1 items-center"
                    aria-label={`${review.rating} out of 5 stars`}
                  >
                    <span aria-hidden="true">{"★".repeat(review.rating)}</span>
                  </div>
                </div>
              </div>
              <div class="flex-grow flex flex-col">
                <p id={reviewId} data-expanded="false" class="text-gray-700">
                  {truncatedText}
                </p>
                <div class="flex-grow" />
                {isLongReview && (
                  <button
                    type="button"
                    class="mt-2 px-3 py-1 text-sm font-semibold text-blue-700 bg-blue-50 rounded hover:bg-blue-100 transition read-more-btn self-start"
                    data-review-id={reviewId}
                    data-full-text={review.text}
                    data-truncated-text={truncatedText}
                  >
                    Read more
                  </button>
                )}
                <a
                  href={GOOGLE_REVIEWS_URL}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs text-gray-400 hover:text-gray-600 mt-3 self-end flex items-center justify-end gap-1"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M21.35 11.1h-9.18v2.96h5.48c-.24 1.48-1.55 4.34-5.48 4.34-3.29 0-6-2.7-6-6s2.71-6 6-6c1.87 0 3.12.8 3.84 1.5l2.63-2.54C17.73 3.51 15.09 2 12 2 6.48 2 2 6.48 2 12s4.48 10 10 10c5.33 0 9.75-3.89 9.75-9.7 0-.65-.07-1.14-.16-1.6z" />
                  </svg>
                  Google
                </a>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    function setupReadMoreButtons() {
      document.addEventListener("click", (e) => {
        const target = e.target;
        if (!target || !(target instanceof HTMLElement)) return;

        const button = target.closest(".read-more-btn");
        if (!button) return;

        const reviewId = button.getAttribute("data-review-id");
        const fullText = button.getAttribute("data-full-text");
        const truncatedText = button.getAttribute("data-truncated-text");
        if (!reviewId || !fullText || !truncatedText) return;

        const reviewElement = document.getElementById(reviewId);
        if (!reviewElement) return;

        const isExpanded =
          reviewElement.getAttribute("data-expanded") === "true";

        reviewElement.textContent = isExpanded ? truncatedText : fullText;
        reviewElement.setAttribute("data-expanded", String(!isExpanded));
        button.textContent = isExpanded ? "Read more" : "Read less";
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupReadMoreButtons);
    } else {
      setupReadMoreButtons();
    }
  })();
</script>
