---
import { Image } from "astro:assets";
import studWall from "../assets/images/stud-wall-new-build.jpeg";
import mouldingPlane from "../assets/images/moulding_plane.png";
import gardenRooms from "../assets/images/garden-rooms/garden-rooms.jpeg";
import kitchenInstallers from "../assets/images/Kitchen-Installers.jpg";
import cutRoofHeader from "../assets/images/cut-roofs/cut-roof-header.jpg";
import steelFireExit from "../assets/images/steel-exit-doors/Security-Fire-Exit-Door-510x510.jpg";
import smallBuildImage from "../assets/images/small-build-services/small-building-works-glazed-office-800x600.jpg";
import doorImage from "../assets/images/doors/fire-doors1.jpg";
import joinerImage from "../assets/images/general-joinery/fencing-and-gates.jpg";

const services = [
  {
    title: "Joiner",
    href: "/joinery-services/joiner",
    image: joinerImage,
    alt: "Qualified joiner in York and Yorkshire",
    description: "Doors, floors, stairs, shelves, storage and all general joinery work.",
    category: "Joinery",
  },
  {
    title: "Door Hanging",
    href: "/joinery-services/door-hanging",
    image: doorImage,
    alt: "Door hanging and fitting service in York",
    description: "Internal, external and fire door hanging — hung straight, sealed and finished.",
    category: "Joinery",
  },
  {
    title: "Fitted Kitchens",
    href: "/joinery-services/kitchen-installers",
    image: kitchenInstallers,
    alt: "Fitted Kitchen and Installers York",
    description: "Full kitchen installs tailored to your layout and finish.",
    category: "Kitchens",
  },
  {
    title: "Bespoke Joinery",
    href: "/joinery-services/bespoke-joinery",
    image: mouldingPlane,
    alt: "Bespoke Joinery",
    description: "Made-to-measure joinery tailored to your space and style.",
    category: "Bespoke",
  },
  {
    title: "Garden Rooms",
    href: "/joinery-services/garden-rooms",
    image: gardenRooms,
    alt: "Bespoke garden room built with timber cladding in York",
    description: "Garden rooms and offices — insulated, tailored, and built to last.",
    category: "Bespoke",
  },
  {
    title: "Small Build Services",
    href: "/joinery-services/small-build-services",
    image: smallBuildImage,
    alt: "Small build services including extensions and renovations in York",
    description: "Extensions, renovations, maintenance, and small construction projects.",
    category: "Building",
  },
  {
    title: "Stud Walls",
    href: "/joinery-services/stud-wall-partitioning",
    image: studWall,
    alt: "stud wall and partitioning installers in York",
    description: "Room layouts adapted with solid timber studwork.",
    category: "Construction",
  },
  {
    title: "Traditional Cut Roofs",
    href: "/joinery-services/traditional-cut-roofs",
    image: cutRoofHeader,
    alt: "Traditional cut roofs and timber roof framing in York",
    description: "Cut roofs and truss roofs — hand-cut or prefabricated, fitted on site.",
    category: "Roofing",
  },
  {
    title: "Steel Fire Exit Doors",
    href: "/joinery-services/steel-fire-exit-doors-installers",
    image: steelFireExit,
    alt: "Steel fire exit and fire escape doors",
    description: "Robust, compliant fire exit doors for commercial spaces.",
    category: "Commercial",
  },
];
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 max-w-7xl mx-auto">
  {
    services.map((service, index) => (
      <a
        href={service.href}
        class="group relative bg-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 ease-in-out hover:-translate-y-1 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2"
        aria-label={`Learn more about ${service.title} services`}
      >
        <!-- Image Container -->
        <div class="relative overflow-hidden rounded-t-xl">
          <Image
            src={service.image}
            alt={service.alt}
            loading={index < 4 ? "eager" : "lazy"}
            priority={index < 4}
            width={400}
            height={300}
            decoding="async"
            format="webp"
            quality={80}
            class="w-full h-48 object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <!-- Overlay on hover -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          
          <!-- Service badge -->
          <div class="absolute top-3 left-3">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-brand-100 text-brand-800">
              {service.title}
            </span>
          </div>
        </div>

        <!-- Content -->
        <div class="p-6">
          <h3 class="text-lg font-semibold text-brand-900 mb-2 group-hover:text-brand-600 transition-colors duration-200">
            {service.title}
          </h3>
          <p class="text-sm text-brand-600 leading-relaxed">
            {service.description}
          </p>
          
          <!-- CTA Arrow -->
          <div class="mt-4 flex items-center text-brand-500 group-hover:text-brand-600 transition-colors duration-200">
            <span class="text-sm font-medium">Learn more</span>
            <svg 
              class="w-4 h-4 ml-2 transform group-hover:translate-x-1 transition-transform duration-200" 
              fill="none" 
              stroke="currentColor" 
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </div>
        </div>

        <!-- Hover effect border -->
        <div class="absolute inset-0 rounded-xl border-2 border-transparent group-hover:border-brand-200 transition-colors duration-300 pointer-events-none"></div>
      </a>
    ))
  }
</div>
