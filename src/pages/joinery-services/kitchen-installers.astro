---
import Layout from "../../layouts/Layout.astro";
import ModernContactForm from "../../components/ModernContactForm.astro";
import { getFormattedPageData } from "../../utils/pageMeta";
import ReviewsLinkSection from "../../components/ReviewsLinkSection.astro";
import ServiceHero from "../../components/ServiceHero.astro";
import MeetRobertCard from "../../components/MeetRobertCard.astro";
import ServiceFeatureCard from "../../components/ServiceFeatureCard.astro";

// import NearbyAreas from "../../components/NearbyAreasList.astro";
import NearbyAreas from "../../components/NearbyAreasKitchenInstallers.astro"; // this location is unique a specific for the service offered !! CHECK

import GalleryGrid from "../../components/GalleryGrid.astro";
import galleryImg1 from "../../assets/images/kitchens/kitchen-fitter-domestic.jpg";
import galleryImg2 from "../../assets/images/kitchens/kitchen-commercial.jpg";
import galleryImg3 from "../../assets/images/kitchens/Kitchen-fitter4.jpg";
import galleryImg4 from "../../assets/images/accessible-kitchens/accessible-kitchen-main.jpg";
import galleryImg5 from "../../assets/images/kitchens/birkby-kitchen.jpg";
import galleryImg6 from "../../assets/images/kitchens/kitchen-fitter2.jpg";


const {
  formattedServiceName,
  locationInText,
  cleanLocationName,
  businessSchema,
  serviceSchema,
  faqSchema,
  defaultDescription,
  enhancedKeywords,
  enhancedDescription,
  pageTitle,
} = getFormattedPageData(Astro);

const description = `Expert kitchen installation ${locationInText} by City & Guilds qualified joiner. Domestic & trade kitchen fitting. Joiner since 1988, quality craftsmanship.`;
const finalDescription =
  enhancedDescription || description || defaultDescription;
---

<Layout
  title={`${pageTitle} | Experienced Kitchen Installer & Fitter for Domestic & Trade Projects`}
  description={finalDescription}
  keywords={enhancedKeywords}
  structuredData={businessSchema}
>
  <Fragment slot="head">
    <script is:inline
      type="application/ld+json"
      set:html={JSON.stringify(businessSchema)}
    />
    <script is:inline
      type="application/ld+json"
      set:html={JSON.stringify(serviceSchema)}
    />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <main class="mx-auto relative z-10">
    <ServiceHero
      badge="Fitted Kitchens"
      title={pageTitle}
      description={`I'm Robert, a City & Guilds qualified joiner with experience going back to 1988 fitting kitchens ${locationInText}. Whether you've already chosen your kitchen or need a made-to-measure solution for an awkward space, I'll survey, plan and source it — then fit it properly. No shortcuts.`}
      breadcrumbCrumbs={[
        { label: "Joinery Services", href: "/joinery-services" },
        ...(cleanLocationName
          ? [
              {
                label: formattedServiceName,
                href: `/joinery-services/${formattedServiceName.toLowerCase().replace(/\s+/g, "-")}`,
              },
              { label: cleanLocationName, current: true },
            ]
          : [{ label: formattedServiceName, current: true }]),
      ]}
    />

    <!-- Main Content Section -->
    <section class="bg-white py-12 lg:py-16">
      <div class="container-wide">
        <div class="grid lg:grid-cols-2 items-start gap-12 lg:gap-16">
          <!-- Content Column -->
          <div class="order-2 lg:order-1">
            <div class="space-y-8 text-neutral-700">
              <MeetRobertCard
                introText={`I've been fitting kitchens since 1988 ${locationInText}, and I still love the craft. When you work with me, you're dealing directly with me — no sales team, no middlemen. I'll measure up, talk through what you need, and then get on with fitting it properly. Simple as that.`}
              />

              <div class="space-y-5 text-neutral-700 leading-relaxed">
                <p>
                  I fit kitchens in all sorts of places — your home, rental properties, offices, even the odd commercial kitchen. 
                  Over the years I've done everything from single domestic fits to multi-unit developments and trade work. 
                  The approach is always the same: measure carefully, fit precisely, finish properly.
                </p>
                {
                  cleanLocationName && (
                    <p>
                      Working in {cleanLocationName} means I see a real mix — period properties needing careful retrofits, 
                      new builds with open-plan layouts, everything in between. I'll always take the time to understand 
                      how you're going to use the space, then fit it accordingly. A kitchen that looks right and works right.
                    </p>
                  )
                }
                <p>
                  If you've already got your kitchen units sorted, great — I'll fit them. If you're still deciding, 
                  I'm happy to chat through options and help you choose something that'll work well for your space and budget.
                </p>
              </div>

              {
                /* Supplier logos removed. They had gone stale: two suppliers were
                   still advertised years after Robert stopped using them, drawing
                   search impressions (159, zero clicks) for work he no longer takes.
                   The third earned no impressions at all, so its logo carried no SEO
                   value either.

                   Replaced with copy, because the real differentiator cannot be shown
                   with a logo: Coulsy Joinery does NOT manufacture and has no workshop,
                   but it does far more than fit flat-pack. It SPECIFIES, SOURCES and
                   INSTALLS — including made-to-measure cabinets and doors from
                   specialist manufacturers. Never let this wording imply manufacturing
                   or a workshop. See ARCHITECTURE.md. */
              }
              <div class="bg-white border border-neutral-200 rounded-lg p-6">
                <h2 class="text-lg font-bold text-neutral-900 mb-3">
                  Standard Kitchens or Made-to-Measure Solutions
                </h2>
                <p class="text-neutral-700 mb-4 leading-relaxed text-sm">
                  Whether you've already chosen a kitchen from DIY Kitchens or
                  another supplier, or need a made-to-measure solution for a more
                  challenging space, I can survey, plan and source cabinets and
                  doors to suit your property before carrying out a professional
                  installation.
                </p>
                <p class="text-neutral-700 leading-relaxed text-sm">
                  From the initial survey through to the finished installation, the
                  same experienced joiner manages the work. The name on the cabinets
                  matters far less than the quality of the fitting.
                </p>
              </div>

              <!-- Services Section -->
              <div class="space-y-4">
                <div class="border-l-4 border-brand-500 py-6" style="padding-left: 1.5rem;">
                  <h3 class="text-lg font-semibold text-neutral-900 mb-2">
                    Domestic Kitchen Fitting
                  </h3>
                  <p class="text-neutral-700 leading-relaxed">
                    Most of my work is fitting kitchens in people's homes {locationInText}. 
                    Whether it's a full renovation or part of a new build, I'll make sure 
                    everything lines up properly and finishes cleanly.
                  </p>
                </div>

                <div class="border-l-4 border-brand-500 py-6" style="padding-left: 1.5rem;">
                  <h3 class="text-lg font-semibold text-neutral-900 mb-2">
                    Commercial & Trade Work
                  </h3>
                  <p class="text-neutral-700 leading-relaxed">
                    I also fit kitchens for offices, retail spaces, and hospitality venues {locationInText}. 
                    Same attention to detail, just working around business hours when needed.
                  </p>
                </div>

                <div class="border-l-4 border-brand-500 py-6" style="padding-left: 1.5rem;">
                  <h3 class="text-lg font-semibold text-neutral-900 mb-2">
                    Accessible Kitchens
                  </h3>
                  <p class="text-neutral-700 leading-relaxed mb-2">
                    I can adapt kitchens for wheelchair users or reduced mobility — lowered worktops, 
                    accessible storage, the works. It's about making the space work for you, safely and comfortably.
                  </p>
                  <a
                    href="/joinery-services/accessible-kitchen-installers"
                    class="text-brand-600 hover:text-brand-700 font-medium text-sm inline-flex items-center gap-1"
                  >
                    Find out more about accessible kitchens
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </a>
                </div>
              </div>

              <!-- Why Choose Me Section -->
              <div class="bg-brand-50 border-l-4 border-brand-600 p-6 rounded-r-lg">
                <h2 class="text-xl font-bold text-neutral-900 mb-4">
                  Why Work With Me?
                </h2>
                <div class="space-y-5 text-neutral-700">
                  <div>
                    <h3 class="font-semibold text-neutral-900 mb-1.5">
                      I turn up when I say I will
                    </h3>
                    <p class="leading-relaxed text-sm">
                      No disappearing acts, no excuses. If I say I'll be there Tuesday morning, I'll be there. 
                      Simple reliability goes a long way.
                    </p>
                  </div>
                  <div>
                    <h3 class="font-semibold text-neutral-900 mb-1.5">
                      hands-on experience going back to 1988
                    </h3>
                    <p class="leading-relaxed text-sm">
                      I've seen most problems before, and I know how to solve them properly. 
                      That experience shows in the finish — everything lines up, everything works.
                    </p>
                  </div>
                  <div>
                    <h3 class="font-semibold text-neutral-900 mb-1.5">
                      Most of my work comes from recommendations
                    </h3>
                    <p class="leading-relaxed text-sm">
                      A lot of my kitchen work {locationInText} comes from people who've worked with me before, 
                      or friends of theirs. That means something to me, and I work hard to keep earning it.
                    </p>
                  </div>
                </div>
              </div>

              <ReviewsLinkSection />
            </div>
          </div>

          <!-- Sidebar Column -->
          <div class="order-1 lg:order-2">
            <div class="space-y-6">
              <!-- Gallery Section -->
              <div class="card card-hover overflow-hidden">
                <div class="card-header">
                  <h2 class="text-xl font-bold text-neutral-900">
                    Some Recent Kitchen Projects
                  </h2>
                  <p class="text-neutral-600 mt-2 text-sm">
                    A few examples of kitchens I've fitted recently
                  </p>
                </div>
                <div class="card-body p-0">
                  <GalleryGrid
                    items={[
                      {
                        src: galleryImg1,
                        alt: `Domestic kitchen installation in ${cleanLocationName}`,
                        label: "Domestic Kitchen Installation",
                      },
                      {
                        src: galleryImg2,
                        alt: `Commercial kitchen fitted for hospitality use in ${cleanLocationName}`,
                        label: "Large Commercial Kitchen Fit-Out",
                      },
                      {
                        src: galleryImg3,
                        alt: `Modern kitchen design and installation in ${cleanLocationName}`,
                        label: "Contemporary Kitchen Setup",
                      },
                      {
                        src: galleryImg4,
                        alt: `Accessible kitchen installation designed for reduced mobility in ${cleanLocationName}`,
                        label: "Accessible Kitchen Design",
                      },
                      {
                        src: galleryImg5,
                        alt: `Modern kitchen installation by experienced joiners in ${cleanLocationName}`,
                        label: "Modern Kitchen Installed",
                        loading: "lazy",
                      },
                      {
                        src: galleryImg6,
                        alt: `Precision joinery on a kitchen installation in ${cleanLocationName}, made-to-measure cabinets fitted by a qualified joiner`,
                        label: "Precision Kitchen Fitting",
                        loading: "lazy",
                      },
                    ]}
                  />
                </div>
              </div>

              <!-- Contact Form Section -->
              <div class="card card-hover bg-brand-600 text-white">
                <div class="card-body">
                  <div class="mb-6">
                    <h2 class="text-xl font-bold mb-2">Want to Chat About Your Kitchen?</h2>
                    <p class="text-brand-100 text-sm leading-relaxed">
                      If you're planning a new kitchen or need an existing one refitted, 
                      drop me a message. I'm happy to talk through what you need and give you 
                      a straightforward quote — no hard sell, just honest advice.
                    </p>
                  </div>
                  <ModernContactForm
                    title=""
                    subtitle=""
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Nearby Areas Section -->
    <section class="bg-neutral-50 py-12 lg:py-16">
      <div class="container-wide">
        <NearbyAreas location={Astro.params.location} />
      </div>
    </section>
  </main>
</Layout>
